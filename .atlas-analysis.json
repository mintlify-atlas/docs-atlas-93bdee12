  "keyFeatures": [
    "AI-generated personalized 4-week learning plans (interpretive and analytical modes)",
    "Soft skills assessment integrated into learning path generation",
    "Focus cards system with priority-tiered study topics (2 High / 2 Medium / 2 Low)",
    "AI Trainer chat for on-demand tutoring powered by Groq LLM",
    "Team Leader analytics dashboard with at-risk student identification",
    "Automated AI reports for clans and cohorts",
    "Activity progress tracking with evidence submission",
    "Hybrid Node.js + Python/FastAPI microservice architecture",
    "Social authentication (GitHub, Google) and email/password login",
    "Semantic search using sentence-transformers embeddings"
  ],
  "publicApiSurface": [
    "POST /generate-plan — Generate a personalized learning plan for a coder",
    "POST /generate-focus-cards — Generate 6 priority-tiered study cards",
    "POST /chat/ask — AI tutor chat endpoint",
    "POST /generate-report — Generate a TL analytics report",
    "POST /generate-exercise — Generate a coding exercise",
    "GET /health — AI service health check",
    "POST /api/auth/login — User login",
    "POST /api/auth/register — User registration",
    "GET /api/coder/dashboard — Coder dashboard data",
    "GET /api/tl/dashboard — Team Leader dashboard data",
    "GET /api/notifications — User notifications",
    "POST /api/assignments — Assignment management"
  ]
